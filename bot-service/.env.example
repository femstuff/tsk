TG_TOKEN=your_telegram_bot_token
SERV_PORT=8080
DIRECTORY=./downloads

# Python transcription service
TRANSCRIBE_API_URL=http://localhost:8000/transcribe

# LLM API (OpenAI-compatible Chat Completions)
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-4o-mini

# Bitrix24 inbound webhook:
# https://<domain>.bitrix24.ru/rest/<user_id>/<webhook_code>
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your_webhook
BITRIX_DEFAULT_STAGE_ID=C1:NEW
