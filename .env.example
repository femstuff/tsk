# Bitrix (корень репозитория, подхватывается docker compose)
BITRIX_WEBHOOK_URL=

# Поле «Смета» в карточке сделки (тип «файл»). Пусто — искать по подписи «Смета» в crm.deal.fields.
BITRIX_DEAL_ESTIMATE_FIELD=UF_CRM_1780312932196

# LLM для разбора полей сметы после Whisper (backend-api)
# Без LLM_API_KEY работает только regex-парсер.
#
# Вариант A — OpenRouter (есть бесплатные модели): https://openrouter.ai/keys
# LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_API_KEY=sk-or-v1-...
# LLM_MODEL=google/gemini-2.0-flash-lite-001
#
# Вариант B — Groq (бесплатный tier): https://console.groq.com/keys
# LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile
#
# Вариант C — Google AI Studio (Gemini): https://aistudio.google.com/apikey
# LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# LLM_API_KEY=...
# LLM_MODEL=gemini-2.0-flash

LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
